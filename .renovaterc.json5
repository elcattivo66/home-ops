{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>home-operations/renovate-presets#2.1.0",
    "github>elcattivo66/home-ops//.renovate/autoMerge.json5",
    "github>elcattivo66/home-ops//.renovate/groups.json5",
    "github>elcattivo66/home-ops//.renovate/labels.json5",
    "github>elcattivo66/home-ops//.renovate/overrides.json5",
    "github>elcattivo66/home-ops//.renovate/packageRules.json5",
    ":timezone(Europe/Berlin)",
  ],
  "ignorePaths": ["**/*.sops.*", "**/.archive/**", "**/config/**"],
  "packageRules": [
    {
      "description": "Disable digest-only updates for CNPG PostgreSQL images",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql",
        "ghcr.io/cloudnative-pg/postgis-extension"
      ],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    }
  ]
}
